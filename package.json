{
	"name": "civilio",
	"version": "4.3.1",
	"productName": "CivilIO",
	"displayName": "CivilIO",
	"description": "A cross-platform civil status survey data management tool.",
	"main": "./dist/electron/index.js",
	"license": "ISC",
	"scripts": {
		"translate": "node translate.mjs --input path=./assets/i18n/en.yml lang=en --output lang=fr",
		"translate:watch": "nodemon --config nodemon.translate.json",
		"ng": "ng",
		"start:ng": "ng serve",
		"build:ng": "ng build --output-path ./dist/angular --configuration production",
		"wait-on:ng": "wait-on http://localhost:4200",
		"predev": "pnpm clean",
		"dev": "pnpm manifest && concurrently -n \"angular-dev,electron,translate\" \"pnpm start:ng\" \"nodemon\" \"pnpm translate:watch\"",
		"start:electron": "electron-forge start",
		"build:electron": "pnpm build:electron:webpack",
		"build:electron:webpack": "webpack --config webpack.main.config.js && webpack --config webpack.preload.config.js",
		"make:electron": "pnpm clean && pnpm manifest && pnpm build:ng && pnpm build:electron && wait-on dist/electron/index.js dist/electron/preload.js && electron-forge make",
		"clean": "pnpm exec rimraf dist out",
		"package:electron": "pnpm clean && pnpm manifest && pnpm build:ng && pnpm build:electron && wait-on dist/electron/index.js dist/electron/preload.js && electron-forge package",
		"watch": "ng build --watch --configuration development",
		"migrate.local": "pnpm drizzle-kit generate && pnpm drizzle-kit migrate",
		"drop.local": "pnpm drizzle-kit drop",
		"studio": "pnpm drizzle-kit studio",
		"prepublish:electron": "pnpm clean && pnpm build:electron && pnpm build:ng && pnpm manifest",
		"sdk:update": "pnpm orval --clean",
		"publish:electron": "electron-forge publish",
		"g:page": "ng g c --project civilio --type page",
		"g:layout": "ng g c --project civilio --type layout",
		"g:component": "ng g c --project civilio --type component -c OnPush",
		"g:guard": "ng g g --project civilio",
		"g:pipe": "ng g p --project civilio",
		"test": "ng test",
		"release": "standard-version",
		"manifest": "node build-info.mjs"
	},
	"private": true,
	"dependencies": {
		"@angular/cdk": "^22.0.1",
		"@angular/common": "^22.0.1",
		"@angular/compiler": "^22.0.1",
		"@angular/core": "^22.0.1",
		"@angular/forms": "^22.0.1",
		"@angular/platform-browser": "^22.0.1",
		"@angular/router": "^22.0.1",
		"@ng-icons/core": "^32.5.0",
		"@ng-icons/lucide": "^32.5.0",
		"@ngx-translate/core": "^17.0.0",
		"@ngxs/logger-plugin": "^20.1.0",
		"@ngxs/router-plugin": "^20.1.0",
		"@ngxs/storage-plugin": "^21.0.0",
		"@ngxs/store": "^20.1.0",
		"@spartan-ng/brain": "0.0.1-alpha.640",
		"@tanstack/angular-db": "^0.1.68",
		"@tanstack/angular-form": "^1.33.0",
		"@tanstack/angular-table": "^8.21.4",
		"@tanstack/db": "^0.6.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"dexie": "^4.4.3",
		"drizzle-orm": "^0.44.7",
		"electron-log": "^5.4.4",
		"electron-squirrel-startup": "^1.0.1",
		"electron-store": "^10.1.0",
		"embla-carousel-angular": "^22.0.0",
		"immer": "^11.1.8",
		"inter-ui": "^4.1.1",
		"json-logic-engine": "^5.0.7",
		"leaflet": "^1.9.4",
		"lodash": "^4.18.1",
		"lru-cache": "^11.5.1",
		"mime-types": "^3.0.2",
		"mustargs": "^1.0.8",
		"ngx-sonner": "^3.1.0",
		"ngxtension": "^6.0.0",
		"node-machine-id": "^1.1.12",
		"pg": "^8.21.0",
		"preferences": "^2.0.2",
